{
  "oversized_in_gui": true,
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/light_gray_stained_glass_pane"
    },
    "cases": [
      {
        "when": "GUI_PREVIOUS",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/previous_button"
        }
      },
      {
        "when": "GUI_NEXT",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/next_button"
        }
      },
      {
        "when": "GUI_UP",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/up_button"
        }
      },
      {
        "when": "GUI_DOWN",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/down_button"
        }
      },
      {
        "when": "GUI_CONFIRM",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/confirm_button"
        }
      },
      {
        "when": "GUI_INVISIBLE",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/invisible_button"
        }
      },
      {
        "when": "GUI_PREVIOUS_DISABLED",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/previous_disabled"
        }
      },
      {
        "when": "GUI_NEXT_DISABLED",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/next_disabled"
        }
      },
      {
        "when": "GUI_UP_DISABLED",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/up_disabled"
        }
      },
      {
        "when": "GUI_DOWN_DISABLED",
        "model": {
          "type": "minecraft:model",
          "model": "darksoul:gui/down_disabled"
        }
      }
    ]
  }
}
